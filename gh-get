#!/usr/bin/env bash
set -euo pipefail

print_help() {
  cat <<'HELP'
Download a file or directory from a GitHub repo without cloning it.

Usage:
  gh get <repo|owner/repo> <path/in/repo> [--ref <ref>] [--force] [output]

Options:
  -f, --force  Overwrite existing file.
  --ref        Branch, tag, or commit. Default: main

Notes:
  @alias resolves a path from .gh-get.json in the target repo at the selected ref.

Examples:
  gh get github/gitignore README.md
  gh get github/gitignore Global/macOS.gitignore --ref main .gitignore
  gh get owner/repo @mac
HELP
}

force=0
ref="main"
positional_args=()
while [[ $# -gt 0 ]]; do
  arg="$1"
  case "$arg" in
    -h|--help|help)
      print_help
      exit 0
      ;;
    -f|--force)
      force=1
      shift
      ;;
    --ref)
      if [[ $# -lt 2 ]]; then
        echo "Error: --ref requires a value." >&2
        exit 1
      fi
      ref="$2"
      shift 2
      ;;
    --ref=*)
      ref="${arg#*=}"
      shift
      ;;
    *)
      positional_args+=("$arg")
      shift
      ;;
  esac
done
set -- "${positional_args[@]}"

if [[ $# -lt 2 || $# -gt 3 ]]; then
  echo "Run: gh get --help" >&2
  exit 1
fi

repo_input="$1"
file_path="$2"
out="${3:-$(basename "$file_path")}"

repo="$repo_input"
if [[ "$repo_input" != */* ]]; then
  owner="$(gh api user -q .login)"
  repo="$owner/$repo_input"
fi

if [[ "$file_path" == @* ]]; then
  alias_name="${file_path#@}"
  if [[ -z "$alias_name" ]]; then
    echo "Error: alias name is missing after '@'." >&2
    exit 1
  fi

  config_path=".gh-get.json"

  # Fetch JSON via the contents API and decode. We avoid relying on an external `jq`
  # binary; `gh api --jq` provides jq filtering.
  encoded_content=""
  if ! encoded_content="$(gh api "repos/$repo/contents/$config_path?ref=$ref" --jq .content 2>/dev/null)"; then
    echo "Error: alias config '$config_path' not found in '$repo' at ref '$ref'." >&2
    exit 1
  fi

  if [[ -z "$encoded_content" || "$encoded_content" == "null" ]]; then
    echo "Error: alias config '$config_path' is missing content." >&2
    exit 1
  fi

  config_json="$(printf '%s' "$encoded_content" | tr -d '\n' | base64 -d 2>/dev/null || true)"
  if [[ -z "$config_json" ]]; then
    echo "Error: failed to decode alias config '$config_path'." >&2
    exit 1
  fi

  file_path="$(
    printf '%s' "$config_json" | python3 -c 'import json,sys
alias=sys.argv[1]
config_path=sys.argv[2]
try:
  data=json.load(sys.stdin)
except Exception:
  print(f"Error: invalid JSON in '{config_path}'.", file=sys.stderr)
  sys.exit(1)
aliases=data.get("aliases")
if not isinstance(aliases, dict):
  print(f"Error: invalid alias config '{config_path}'. Expected object at .aliases.", file=sys.stderr)
  sys.exit(1)
if alias not in aliases:
  keys=sorted([str(k) for k in aliases.keys()])
  if not keys:
    print(f"Error: alias '@{alias}' not found. No aliases are configured.", file=sys.stderr)
  else:
    print("Error: alias '@%s' not found. Available aliases: %s" % (alias, ", ".join(keys)), file=sys.stderr)
  sys.exit(1)
value=aliases[alias]
if not isinstance(value, str):
  print(f"Error: alias '@{alias}' must be a string path in '{config_path}'.", file=sys.stderr)
  sys.exit(1)
if not value:
  print(f"Error: alias '@{alias}' must not be empty in '{config_path}'.", file=sys.stderr)
  sys.exit(1)
print(value)
' "$alias_name" "$config_path"
  )"
  out="${3:-$(basename "$file_path")}"
fi

path_type="$(gh api "repos/$repo/contents/$file_path?ref=$ref" --jq 'if type == "array" then "dir" else .type end')"

temp_output=""
temp_extract=""
temp_tar=""
cleanup() {
  [[ -n "$temp_output" ]] && rm -f "$temp_output"
  [[ -n "$temp_extract" ]] && rm -rf "$temp_extract"
  [[ -n "$temp_tar" ]] && rm -f "$temp_tar"
}
trap cleanup EXIT

target_output_path="$out"
if [[ "$out" == */ ]]; then
  mkdir -p "$out"
  target_output_path="$out$(basename "$file_path")"
elif [[ -d "$out" ]]; then
  echo "Error: '$out' is a directory. Use a trailing '/' to write into it." >&2
  exit 1
fi

if [[ "$path_type" == "dir" ]]; then
  # still prevent dir overriding even with --force
  if [[ -e "$target_output_path" ]]; then
    echo "Error: '$target_output_path' already exists." >&2
    exit 1
  fi
  temp_tar="$(mktemp)"
  temp_extract="$(mktemp -d)"
  gh api "repos/$repo/tarball/$ref" >"$temp_tar"
  tar -xzf "$temp_tar" -C "$temp_extract"
  root_dir="$(find "$temp_extract" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  if [[ -z "$root_dir" || ! -e "$root_dir/$file_path" ]]; then
    echo "Error: failed to extract directory '$file_path' from archive." >&2
    exit 1
  fi
  mv "$root_dir/$file_path" "$target_output_path"
elif [[ "$path_type" == "file" ]]; then
  if [[ -d "$target_output_path" ]]; then
    echo "Error: '$target_output_path' is a directory." >&2
    exit 1
  fi
  if [[ "$force" -ne 1 && -e "$target_output_path" ]]; then
    echo "Error: '$target_output_path' already exists." >&2
    exit 1
  fi
  temp_output="$(mktemp)"
  gh api \
    -H "Accept: application/vnd.github.raw" \
    "repos/$repo/contents/$file_path?ref=$ref" \
    >"$temp_output"
  # use temp file to avoid writing errors as file
  mv -f "$temp_output" "$target_output_path"
else
  echo "Error: unsupported path type '$path_type'." >&2
  exit 1
fi

trap - EXIT
