#!/usr/bin/env bash
set -euo pipefail

print_help() {
  cat <<'HELP'
Download a file or directory from a GitHub repo without cloning it.

Usage:
  gh get <repo|owner/repo> <path/in/repo> [--ref <ref>] [--force] [output]

Options:
  -f, --force  Overwrite existing file.
  --ref        Branch, tag, or commit. Default: main

Notes:
  @alias resolves a path from .gh-get.json in the target repo at the selected ref.

Examples:
  gh get github/gitignore README.md
  gh get github/gitignore Global/macOS.gitignore --ref main .gitignore
  gh get github/gitignore @mac
HELP
}

force=0
ref="main"
positional_args=()
while [[ $# -gt 0 ]]; do
  arg="$1"
  case "$arg" in
    -h|--help|help)
      print_help
      exit 0
      ;;
    -f|--force)
      force=1
      shift
      ;;
    --ref)
      if [[ $# -lt 2 ]]; then
        echo "Error: --ref requires a value." >&2
        exit 1
      fi
      ref="$2"
      shift 2
      ;;
    --ref=*)
      ref="${arg#*=}"
      shift
      ;;
    *)
      positional_args+=("$arg")
      shift
      ;;
  esac
done
set -- "${positional_args[@]}"

if [[ $# -lt 2 || $# -gt 3 ]]; then
  echo "Run: gh get --help" >&2
  exit 1
fi

repo_input="$1"
file_path="$2"
out="${3:-$(basename "$file_path")}"

repo="$repo_input"
if [[ "$repo_input" != */* ]]; then
  owner="$(gh api user -q .login)"
  repo="$owner/$repo_input"
fi

if [[ "$file_path" == @* ]]; then
  alias_name="${file_path#@}"
  if [[ -z "$alias_name" ]]; then
    echo "Error: alias name is missing after '@'." >&2
    exit 1
  fi

  config_json=""
  if ! config_json="$(gh api -H "Accept: application/vnd.github.raw" "repos/$repo/contents/.gh-get.json?ref=$ref" 2>/dev/null)"; then
    echo "Error: alias config '.gh-get.json' not found in '$repo' at ref '$ref'." >&2
    exit 1
  fi

  if ! echo "$config_json" | jq -e . >/dev/null 2>&1; then
    echo "Error: invalid JSON in '.gh-get.json'." >&2
    exit 1
  fi

  if ! echo "$config_json" | jq -e '.aliases | type == "object"' >/dev/null 2>&1; then
    echo "Error: invalid alias config '.gh-get.json'. Expected object at .aliases." >&2
    exit 1
  fi

  if ! echo "$config_json" | jq -e --arg name "$alias_name" '.aliases | has($name)' >/dev/null 2>&1; then
    available_aliases="$(echo "$config_json" | jq -r '.aliases | keys[]?' | paste -sd ", " -)"
    if [[ -z "$available_aliases" ]]; then
      echo "Error: alias '@$alias_name' not found. No aliases are configured." >&2
    else
      echo "Error: alias '@$alias_name' not found. Available aliases: $available_aliases" >&2
    fi
    exit 1
  fi

  if ! echo "$config_json" | jq -e --arg name "$alias_name" '.aliases[$name] | type == "string"' >/dev/null 2>&1; then
    echo "Error: alias '@$alias_name' must be a string path in '.gh-get.json'." >&2
    exit 1
  fi

  file_path="$(echo "$config_json" | jq -r --arg name "$alias_name" '.aliases[$name]')"
  out="${3:-$(basename "$file_path")}"
fi

path_type="$(gh api "repos/$repo/contents/$file_path?ref=$ref" --jq 'if type == "array" then "dir" else .type end')"

temp_output=""
temp_extract=""
temp_tar=""
cleanup() {
  [[ -n "$temp_output" ]] && rm -f "$temp_output"
  [[ -n "$temp_extract" ]] && rm -rf "$temp_extract"
  [[ -n "$temp_tar" ]] && rm -f "$temp_tar"
}
trap cleanup EXIT

target_output_path="$out"
if [[ "$out" == */ ]]; then
  mkdir -p "$out"
  target_output_path="$out$(basename "$file_path")"
elif [[ -d "$out" ]]; then
  echo "Error: '$out' is a directory. Use a trailing '/' to write into it." >&2
  exit 1
fi

if [[ "$path_type" == "dir" ]]; then
  # still prevent dir overriding even with --force
  if [[ -e "$target_output_path" ]]; then
    echo "Error: '$target_output_path' already exists." >&2
    exit 1
  fi
  temp_tar="$(mktemp)"
  temp_extract="$(mktemp -d)"
  gh api "repos/$repo/tarball/$ref" >"$temp_tar"
  tar -xzf "$temp_tar" -C "$temp_extract"
  root_dir="$(find "$temp_extract" -mindepth 1 -maxdepth 1 -type d | head -n 1)"
  if [[ -z "$root_dir" || ! -e "$root_dir/$file_path" ]]; then
    echo "Error: failed to extract directory '$file_path' from archive." >&2
    exit 1
  fi
  mv "$root_dir/$file_path" "$target_output_path"
elif [[ "$path_type" == "file" ]]; then
  if [[ -d "$target_output_path" ]]; then
    echo "Error: '$target_output_path' is a directory." >&2
    exit 1
  fi
  if [[ "$force" -ne 1 && -e "$target_output_path" ]]; then
    echo "Error: '$target_output_path' already exists." >&2
    exit 1
  fi
  temp_output="$(mktemp)"
  gh api \
    -H "Accept: application/vnd.github.raw" \
    "repos/$repo/contents/$file_path?ref=$ref" \
    >"$temp_output"
  # use temp file to avoid writing errors as file
  mv -f "$temp_output" "$target_output_path"
else
  echo "Error: unsupported path type '$path_type'." >&2
  exit 1
fi

trap - EXIT
